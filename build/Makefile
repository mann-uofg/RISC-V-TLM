# target to preprocess a source file
src/extension_base.cpp.i:
	$(MAKE) -f CMakeFiles/RISCV_TLM.dir/build.make CMakeFiles/RISCV_TLM.dir/src/extension_base.cpp.i
.PHONY : src/extension_base.cpp.i

src/extension_base.s: src/extension_base.cpp.s

.PHONY : src/extension_base.s

# target to generate assembly for a file
src/extension_base.cpp.s:
	$(MAKE) -f CMakeFiles/RISCV_TLM.dir/build.make CMakeFiles/RISCV_TLM.dir/src/extension_base.cpp.s
.PHONY : src/extension_base.cpp.s

